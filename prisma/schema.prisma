generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ActivityStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
  UNPUBLISHED
  EXPIRED
}

enum AttendanceStatus {
  GOING
  MAYBE
}

enum AttendanceVisibility {
  PRIVATE
  PUBLIC
}

enum BusinessStatus {
  PENDING
  APPROVED
  SUSPENDED
}

enum BusinessMemberRole {
  OWNER
  EMPLOYEE
}

model User {
  id                      String                  @id @default(cuid())
  name                    String?
  email                   String                  @unique
  emailVerified           DateTime?
  image                   String?
  displayName             String?
  locale                  String                  @default("nl-NL")
  deletionRequestedAt     DateTime?
  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @updatedAt
  accounts                Account[]
  sessions                Session[]
  attendances             Attendance[]
  notificationPreferences NotificationPreference?
  businessMemberships     BusinessMember[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model NotificationPreference {
  id                  String   @id @default(cuid())
  userId              String   @unique
  activityReminders   Boolean  @default(false)
  weeklyDigest        Boolean  @default(false)
  businessUpdates     Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Business {
  id          String         @id @default(cuid())
  slug        String         @unique
  name        String
  status      BusinessStatus @default(PENDING)
  website     String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  activities  Activity[]
  members     BusinessMember[]
}

model BusinessMember {
  id                   String             @id @default(cuid())
  role                 BusinessMemberRole @default(EMPLOYEE)
  active               Boolean            @default(true)
  canPublishActivities Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([userId, businessId])
  @@index([businessId, active])
  @@index([userId, active])
}

model ActivityCategory {
  id         String     @id @default(cuid())
  slug       String     @unique
  name       String
  activities Activity[]
}

model Location {
  id         String     @id @default(cuid())
  slug       String     @unique
  name       String
  address    String?
  activities Activity[]
}

model Activity {
  id               String          @id @default(cuid())
  slug             String          @unique
  title            String
  shortDescription String
  description      String
  imageUrl         String
  startAt          DateTime
  endAt            DateTime
  status           ActivityStatus  @default(PUBLISHED)
  typeTags         String[]
  indoorOutdoor    String?
  expectedVisitors String?
  sourceQuality    String?
  sourceUrl        String
  organizerName    String
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  categoryId String
  category   ActivityCategory @relation(fields: [categoryId], references: [id])

  locationId String
  location   Location @relation(fields: [locationId], references: [id])

  businessId String?
  business   Business? @relation(fields: [businessId], references: [id])

  attendances Attendance[]

  @@index([status, startAt])
  @@index([categoryId, startAt])
  @@index([locationId, startAt])
  @@index([businessId, startAt])
}

model Attendance {
  id         String               @id @default(cuid())
  status     AttendanceStatus     @default(GOING)
  visibility AttendanceVisibility @default(PRIVATE)
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  activityId String
  activity   Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@unique([userId, activityId])
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  action     String
  targetType String
  targetId   String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([targetType, targetId])
  @@index([actorId, createdAt])
}

model FeatureFlag {
  id          String   @id @default(cuid())
  key         String   @unique
  enabled     Boolean  @default(false)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
