generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ActivityStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
  UNPUBLISHED
  EXPIRED
}

enum AttendanceStatus {
  GOING
  MAYBE
}

enum AttendanceVisibility {
  PRIVATE
  PUBLIC
}

enum BusinessStatus {
  PENDING
  APPROVED
  SUSPENDED
}

enum BusinessMemberRole {
  OWNER
  EMPLOYEE
}

enum ReportStatus {
  OPEN
  REVIEWED
  DISMISSED
}

enum AiUsageStatus {
  SUCCEEDED
  BLOCKED
  FAILED
}

enum NotificationCampaignStatus {
  PENDING
  APPROVED
  REJECTED
  SENT
}

enum NotificationDeliveryStatus {
  PENDING
  SKIPPED
  SENT
  FAILED
}

enum PaymentSubscriptionStatus {
  INACTIVE
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
}

enum PaymentTransactionStatus {
  PENDING
  PAID
  FAILED
  CANCELED
  REFUNDED
}

enum WebhookEventStatus {
  RECEIVED
  PROCESSED
  DUPLICATE
  REJECTED
  FAILED
}

enum ActivityScanSourceKind {
  WEBSITE
  GOVERNMENT
  SOCIAL
  RESTAURANT
  BAR
  OTHER
}

enum ActivityScanRunStatus {
  RUNNING
  COMPLETED
  FAILED
}

enum ActivityScanCandidateStatus {
  PENDING
  APPROVED
  REJECTED
  DUPLICATE
  NEEDS_REVIEW
}

model User {
  id                      String                  @id @default(cuid())
  name                    String?
  email                   String                  @unique
  emailVerified           DateTime?
  image                   String?
  displayName             String?
  credentialLogin         String?                 @unique
  passwordHash            String?
  mustChangePassword      Boolean                 @default(false)
  isAdmin                 Boolean                 @default(false)
  disabledAt              DateTime?
  locale                  String                  @default("nl-NL")
  deletionRequestedAt     DateTime?
  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @updatedAt
  accounts                Account[]
  sessions                Session[]
  attendances             Attendance[]
  notificationPreferences NotificationPreference?
  businessMemberships     BusinessMember[]
  reports                 Report[]
  mediaAssets             MediaAsset[]
  aiUsageLogs             AiUsageLog[]
  requestedCampaigns      NotificationCampaign[]  @relation("NotificationCampaignRequester")
  approvedCampaigns       NotificationCampaign[]  @relation("NotificationCampaignApprover")
  notificationDeliveries  NotificationDelivery[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model NotificationPreference {
  id                String   @id @default(cuid())
  userId            String   @unique
  activityReminders Boolean  @default(false)
  weeklyDigest      Boolean  @default(false)
  businessUpdates   Boolean  @default(false)
  categorySlugs     String[] @default([])
  locationSlugs     String[] @default([])
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Business {
  id                    String                 @id @default(cuid())
  slug                  String                 @unique
  name                  String
  status                BusinessStatus         @default(PENDING)
  website               String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  activities            Activity[]
  members               BusinessMember[]
  mediaAssets           MediaAsset[]
  aiUsageLogs           AiUsageLog[]
  notificationCampaigns NotificationCampaign[]
  paymentCustomer       PaymentCustomer?
  paymentSubscriptions  PaymentSubscription[]
  paymentTransactions   PaymentTransaction[]
  invoiceReferences     InvoiceReference[]
}

model BusinessMember {
  id                   String             @id @default(cuid())
  role                 BusinessMemberRole @default(EMPLOYEE)
  active               Boolean            @default(true)
  canPublishActivities Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([userId, businessId])
  @@index([businessId, active])
  @@index([userId, active])
}

model ActivityCategory {
  id         String     @id @default(cuid())
  slug       String     @unique
  name       String
  activities Activity[]
}

model Location {
  id         String     @id @default(cuid())
  slug       String     @unique
  name       String
  address    String?
  activities Activity[]
}

model Activity {
  id               String         @id @default(cuid())
  slug             String         @unique
  title            String
  shortDescription String
  description      String
  imageUrl         String
  startAt          DateTime
  endAt            DateTime
  status           ActivityStatus @default(PUBLISHED)
  typeTags         String[]
  indoorOutdoor    String?
  expectedVisitors String?
  sourceQuality    String?
  sourceUrl        String
  organizerName    String
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  categoryId String
  category   ActivityCategory @relation(fields: [categoryId], references: [id])

  locationId String
  location   Location @relation(fields: [locationId], references: [id])

  businessId String?
  business   Business? @relation(fields: [businessId], references: [id])

  attendances           Attendance[]
  reports               Report[]
  notificationCampaigns NotificationCampaign[]
  analyticsDailyMetrics AnalyticsDailyMetric[]
  scanCandidates        ActivityScanCandidate[]

  @@index([status, startAt])
  @@index([status, organizerName])
  @@index([status, indoorOutdoor])
  @@index([categoryId, startAt])
  @@index([locationId, startAt])
  @@index([businessId, startAt])
}

model Report {
  id         String       @id @default(cuid())
  reason     String
  details    String?
  status     ReportStatus @default(OPEN)
  resolution String?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  reporterId String?
  reporter   User?   @relation(fields: [reporterId], references: [id], onDelete: SetNull)

  activityId String?
  activity   Activity? @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@index([activityId, status])
}

model MediaAsset {
  id           String    @id @default(cuid())
  filename     String
  originalName String
  mimeType     String
  sizeBytes    Int
  width        Int?
  height       Int?
  storageKey   String    @unique
  publicUrl    String
  createdAt    DateTime  @default(now())
  deletedAt    DateTime?

  ownerUserId String
  ownerUser   User   @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)

  businessId String?
  business   Business? @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([ownerUserId, createdAt])
  @@index([businessId, createdAt])
  @@index([deletedAt])
}

model Attendance {
  id         String               @id @default(cuid())
  status     AttendanceStatus     @default(GOING)
  visibility AttendanceVisibility @default(PRIVATE)
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  activityId String
  activity   Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@unique([userId, activityId])
}

model ActivityScanSource {
  id             String                 @id @default(cuid())
  slug           String                 @unique
  name           String
  kind           ActivityScanSourceKind @default(WEBSITE)
  baseUrl        String
  enabled        Boolean                @default(true)
  respectRobots  Boolean                @default(true)
  lastScannedAt  DateTime?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  runs       ActivityScanRun[]
  candidates ActivityScanCandidate[]

  @@index([enabled, kind])
}

model ActivityScanRun {
  id          String                @id @default(cuid())
  status      ActivityScanRunStatus @default(RUNNING)
  startedAt   DateTime              @default(now())
  completedAt DateTime?
  error       String?
  fetchStatus Int?
  contentType String?
  bytesFetched Int?
  fetchedAt   DateTime?
  summary     Json?
  actorId     String?

  sourceId String
  source   ActivityScanSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  candidates ActivityScanCandidate[]

  @@index([sourceId, startedAt])
  @@index([status, startedAt])
}

model ActivityScanCandidate {
  id                    String                      @id @default(cuid())
  status                ActivityScanCandidateStatus @default(PENDING)
  canonicalKey          String                      @unique
  title                 String
  shortDescription      String
  description           String
  imageUrl              String?
  startAt               DateTime
  endAt                 DateTime
  locationName          String
  address               String?
  categorySlug          String
  typeTags              String[]
  indoorOutdoor         String?
  expectedVisitors      String?
  sourceUrl             String
  organizerName         String
  confidence            Int                         @default(60)
  duplicateScore        Int                         @default(0)
  duplicateReason       String?
  qualityScore          Int                         @default(60)
  qualityReasons        String[]                    @default([])
  rejectionReason       String?
  rawEvidence           Json?
  aiNotes               String[]                    @default([])
  reviewedAt            DateTime?
  reviewedById          String?
  createdAt             DateTime                    @default(now())
  updatedAt             DateTime                    @updatedAt

  sourceId String
  source   ActivityScanSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  scanRunId String
  scanRun   ActivityScanRun @relation(fields: [scanRunId], references: [id], onDelete: Cascade)

  approvedActivityId String?
  approvedActivity   Activity? @relation(fields: [approvedActivityId], references: [id], onDelete: SetNull)

  @@index([status, startAt])
  @@index([sourceId, status])
  @@index([scanRunId])
  @@index([approvedActivityId])
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  action     String
  targetType String
  targetId   String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([targetType, targetId])
  @@index([actorId, createdAt])
}

model FeatureFlag {
  id          String   @id @default(cuid())
  key         String   @unique
  enabled     Boolean  @default(false)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AnalyticsDailyMetric {
  id            String   @id @default(cuid())
  day           DateTime
  metric        String
  dimensionsKey String   @default("global")
  activityId    String?
  category      String?
  location      String?
  count         Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  activity Activity? @relation(fields: [activityId], references: [id], onDelete: SetNull)

  @@unique([day, metric, dimensionsKey])
  @@index([metric, day])
  @@index([activityId, day])
}

model PaymentCustomer {
  id                 String   @id @default(cuid())
  provider           String   @default("mollie")
  providerCustomerId String?
  billingEmail       String?
  billingName        String?
  billingReference   String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  businessId String   @unique
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  subscriptions PaymentSubscription[]
  transactions  PaymentTransaction[]
  invoices      InvoiceReference[]

  @@unique([provider, providerCustomerId])
  @@index([provider])
}

model PaymentSubscription {
  id                     String                    @id @default(cuid())
  provider               String                    @default("mollie")
  providerSubscriptionId String?
  planKey                String
  status                 PaymentSubscriptionStatus @default(INACTIVE)
  amountCents            Int                       @default(0)
  currency               String                    @default("EUR")
  currentPeriodStart     DateTime?
  currentPeriodEnd       DateTime?
  canceledAt             DateTime?
  createdAt              DateTime                  @default(now())
  updatedAt              DateTime                  @updatedAt

  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  customerId String?
  customer   PaymentCustomer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  transactions PaymentTransaction[]

  @@unique([provider, providerSubscriptionId])
  @@index([businessId, status])
  @@index([planKey, status])
}

model PaymentTransaction {
  id                    String                   @id @default(cuid())
  provider              String                   @default("mollie")
  providerTransactionId String?
  description           String
  status                PaymentTransactionStatus @default(PENDING)
  amountCents           Int
  currency              String                   @default("EUR")
  paidAt                DateTime?
  failedAt              DateTime?
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  customerId String?
  customer   PaymentCustomer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  subscriptionId String?
  subscription   PaymentSubscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  invoices InvoiceReference[]

  @@unique([provider, providerTransactionId])
  @@index([businessId, createdAt])
  @@index([status, createdAt])
}

model InvoiceReference {
  id            String    @id @default(cuid())
  invoiceNumber String?
  provider      String    @default("internal")
  providerUrl   String?
  amountCents   Int
  currency      String    @default("EUR")
  issuedAt      DateTime?
  dueAt         DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  customerId String?
  customer   PaymentCustomer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  transactionId String?
  transaction   PaymentTransaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)

  @@index([businessId, createdAt])
  @@index([invoiceNumber])
}

model WebhookEventLog {
  id             String             @id @default(cuid())
  provider       String
  eventId        String
  eventType      String
  status         WebhookEventStatus @default(RECEIVED)
  signatureValid Boolean            @default(false)
  payloadSummary Json?
  error          String?
  receivedAt     DateTime           @default(now())
  processedAt    DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@unique([provider, eventId])
  @@index([provider, receivedAt])
  @@index([status, receivedAt])
}

model NotificationCampaign {
  id             String                     @id @default(cuid())
  title          String
  message        String                     @db.Text
  status         NotificationCampaignStatus @default(PENDING)
  targetCategory String?
  targetLocation String?
  requestedAt    DateTime                   @default(now())
  approvedAt     DateTime?
  sentAt         DateTime?
  createdAt      DateTime                   @default(now())
  updatedAt      DateTime                   @updatedAt

  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  activityId String?
  activity   Activity? @relation(fields: [activityId], references: [id], onDelete: SetNull)

  requestedById String
  requestedBy   User   @relation("NotificationCampaignRequester", fields: [requestedById], references: [id], onDelete: Cascade)

  approvedById String?
  approvedBy   User?   @relation("NotificationCampaignApprover", fields: [approvedById], references: [id], onDelete: SetNull)

  deliveries NotificationDelivery[]

  @@index([businessId, requestedAt])
  @@index([status, requestedAt])
  @@index([activityId])
}

model NotificationDelivery {
  id          String                     @id @default(cuid())
  channel     String                     @default("email")
  status      NotificationDeliveryStatus @default(PENDING)
  reason      String?
  provider    String?
  providerId  String?
  attemptedAt DateTime?
  deliveredAt DateTime?
  createdAt   DateTime                   @default(now())
  updatedAt   DateTime                   @updatedAt

  campaignId String
  campaign   NotificationCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([campaignId, userId, channel])
  @@index([userId, createdAt])
  @@index([status, createdAt])
}

model AiPromptTemplate {
  id        String       @id @default(cuid())
  key       String
  version   Int
  title     String
  prompt    String       @db.Text
  active    Boolean      @default(true)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  usageLogs AiUsageLog[]

  @@unique([key, version])
  @@index([key, active])
}

model AiUsageLog {
  id            String        @id @default(cuid())
  action        String
  provider      String
  status        AiUsageStatus @default(SUCCEEDED)
  inputTokens   Int           @default(0)
  outputTokens  Int           @default(0)
  costCents     Int           @default(0)
  inputSummary  String?
  outputSummary String?
  error         String?
  createdAt     DateTime      @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  promptTemplateId String?
  promptTemplate   AiPromptTemplate? @relation(fields: [promptTemplateId], references: [id], onDelete: SetNull)

  @@index([businessId, createdAt])
  @@index([userId, createdAt])
  @@index([action, createdAt])
}
